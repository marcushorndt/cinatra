{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cinatra.ai/contracts/wp-drupal-assistant/v1/sse-event.schema.json",
  "title": "Cinatra WP/Drupal assistant — SSE frame (v1)",
  "description": "Logical shape of one Server-Sent Event the assistant stream emits to the bundle. The wire form is `event: <name>\\ndata: <json>\\n\\n`; this schema models the decoded {event, data} pair. The widget SSE wire format is FROZEN to exactly these four event names: text, changes, error, done.",
  "type": "object",
  "required": ["event", "data"],
  "additionalProperties": false,
  "properties": {
    "event": { "enum": ["text", "changes", "error", "done"] },
    "data": { "type": "object" }
  },
  "oneOf": [
    {
      "title": "text — incremental assistant output",
      "properties": {
        "event": { "const": "text" },
        "data": {
          "type": "object",
          "required": ["content"],
          "additionalProperties": false,
          "properties": { "content": { "type": "string" } }
        }
      }
    },
    {
      "title": "changes — proposed content edit diff",
      "properties": {
        "event": { "const": "changes" },
        "data": {
          "type": "object",
          "required": ["fields"],
          "additionalProperties": false,
          "properties": {
            "fields": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["field", "before", "after"],
                "additionalProperties": false,
                "properties": {
                  "field": { "type": "string" },
                  "before": { "type": "string" },
                  "after": { "type": "string" }
                }
              }
            },
            "nodeId": { "type": "string" },
            "postId": { "type": "string" }
          }
        }
      }
    },
    {
      "title": "error — admin-visible failure message",
      "properties": {
        "event": { "const": "error" },
        "data": {
          "type": "object",
          "required": ["message"],
          "additionalProperties": false,
          "properties": { "message": { "type": "string" } }
        }
      }
    },
    {
      "title": "done — stream terminator",
      "properties": {
        "event": { "const": "done" },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "properties": { "fallback": { "type": "boolean" } }
        }
      }
    }
  ]
}
