+-- Narrow usage_events.cost_usd from numeric(12,8) to numeric(12,4).
+-- The extra scale was never populated (ingest rounds to 4 decimal places)
+-- and the narrower type matches the rollup views. Safe to re-run: converting
+-- a column to the type it already has succeeds as a no-op.
+ALTER TABLE :"schema"."usage_events"
+  ALTER COLUMN cost_usd TYPE numeric(12,4);
