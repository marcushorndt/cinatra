    "services": "set -a && source .env.local && set +a && docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d",
    "services:down": "docker compose down",
    "setup:dev": "node packages/cli/bin/cinatra.mjs setup dev",
    "setup:prod": "node packages/cli/bin/cinatra.mjs setup prod",
    "reset:dev": "node packages/cli/bin/cinatra.mjs reset dev --yes",
    "refresh:dev": "node packages/cli/bin/cinatra.mjs dev refresh",
    "db:migrate": "node packages/cli/bin/cinatra.mjs db migrate",
    "db:migrate:down": "node packages/cli/bin/cinatra.mjs db migrate --down",
    "setup:status": "node packages/cli/bin/cinatra.mjs status",
    "check:services": "node scripts/check-services.mjs",
    "seed": "node --env-file=.env.local scripts/seed.mjs",
    "seed:audit": "node --env-file=.env.local scripts/audit/seed-coverage-gate.mjs",
    "gate:design-packages": "node scripts/audit/design-packages-pack-smoke.mjs",
    "gate:gatekept-install": "node scripts/audit/gatekept-install-no-direct-registry.mjs",
    "backup:create": "node packages/cli/bin/cinatra.mjs backup create",
    "backup:import": "node packages/cli/bin/cinatra.mjs backup import --yes",
    "auth:migrate": "node --env-file-if-exists=.env.local scripts/better-auth-migrate.mts",
    "build:auth-migrate-bundle": "node scripts/build-auth-migrate-bundle.mjs",
    "test:root": "vitest run --config vitest.config.ts --no-coverage",
    "test:e2e:render-smoke": "playwright test -c tests/e2e/config/render-smoke.config.ts",
    "test:e2e:dashboards": "playwright test -c tests/e2e/config/dashboards.config.ts",
    "test:e2e:agents-run": "playwright test -c tests/e2e/config/agents-run.config.ts",
    "test:e2e:notifications": "playwright test -c tests/e2e/config/notifications.config.ts",
    "test:e2e:rbac": "playwright test -c tests/e2e/config/rbac.config.ts",
    "test:e2e:workflows": "playwright test -c tests/e2e/config/workflows.config.ts",
    "test:e2e:wp-drupal": "playwright test -c tests/e2e/config/wp-drupal-uat.config.ts",
    "test:e2e:design": "playwright test -c tests/e2e/config/design.config.ts",
    "test:e2e:design:update": "playwright test -c tests/e2e/config/design.config.ts --update-snapshots",
    "design:scan": "node scripts/design/scan-raw-colors.mjs && node scripts/design/scan-status-render.mjs && node scripts/design/scan-chart-colors.mjs",
    "design:scan:raw": "node scripts/design/scan-raw-colors.mjs",
    "design:scan:status": "node scripts/design/scan-status-render.mjs",
    "design:scan:charts": "node scripts/design/scan-chart-colors.mjs",
    "design:tokens": "node scripts/design/snapshot-tokens.mjs",
    "design:tokens:check": "node scripts/design/snapshot-tokens.mjs --check",
    "design:tokens:write": "node scripts/design/snapshot-tokens.mjs --write"
  },
