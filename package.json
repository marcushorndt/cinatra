    "registryPolicy": {
      "temporary": false,
      "notice": "Private packages on this registry are allowed temporarily and may be deleted without notice."
    },
    "vendoredSkillBundles": [
      {
        "packageName": "@anthropics/skills",
        "destination": "extensions/anthropics/skills",
        "source": {
          "type": "github",
          "owner": "anthropics",
          "repo": "skills",
          "sha": "690f15cac7f7b4c055c5ab109c79ed9259934081",
          "url": "https://github.com/anthropics/skills"
        },
        "license": "Apache-2.0",
        "description": "Skill-authoring methodology (skill-creator) vendored from Anthropic. Used by @cinatra-ai/author-agent when drafting Cinatra extension skills.",
        "include": [
          "THIRD_PARTY_NOTICES.md",
          "skills/skill-creator/SKILL.md",
          "skills/skill-creator/LICENSE.txt"
        ],
        "skills": {
          "skill-creator": {
            "description": "Skill-authoring methodology vendored from Anthropic",
            "matchWhen": {
              "agent_id": "@cinatra-ai/author-agent"
            },
            "level": "workspace",
            "patches": [
              {
                "findAnchor": "---\nname: skill-creator\ndescription: Create new skills, modify and improve existing skills, and measure skill performance. Use when users want to create a skill from scratch, edit, or optimize an existing skill, run evals to test a skill, benchmark skill performance with variance analysis, or optimize a skill's description for better triggering accuracy.\n---\n\n# Skill Creator",
                "replaceWith": "---\nname: skill-creator\ndescription: Authoring methodology for Cinatra catalog SKILL.md files (anatomy, writing style, iteration discipline). NARROWLY APPLICABLE: intended exclusively for @cinatra-ai/author-agent when authoring or improving a SKILL.md on the user's behalf. NOT a general-purpose authoring assistant. The upstream Python eval/benchmark/viewer/packaging harness is NOT vendored in Cinatra; references to those scripts in the methodology below are illustrative — perform their equivalent inline (in conversation) when needed.\nmatch_when:\n  - agent_id: \"@cinatra-ai/author-agent\"\n---\n\n<!--\nCINATRA VENDORING NOTICE\n========================\nVendored from https://github.com/anthropics/skills @ 690f15cac7f7b4c055c5ab109c79ed9259934081\n(skills/skill-creator/SKILL.md). License: Apache-2.0 — verbatim copy in LICENSE.txt next to this file.\nThe upstream eval-viewer / benchmark-aggregator / package-skill / description-optimizer Python\nscripts are NOT vendored. Where the upstream methodology below references those scripts, perform\nthe equivalent inline in the conversation with the user instead of attempting to execute them.\nSee docs/developer/extensions.md for the vendored-bundle pattern.\n-->\n\n# Skill Creator"
              }
            ]
          }
        }
      }
    ]
  },
  "scripts": {
    "vendor:skills": "node scripts/vendor-anthropic-skills.mjs",
    "vendor:skills:check": "node scripts/vendor-anthropic-skills.mjs --check",
    "postinstall": "node scripts/vendor-anthropic-skills.mjs --quiet",
    "dev": "NODE_OPTIONS='--disable-warning=DEP0169 --max-old-space-size=8192' node scripts/dev-server.mjs",
