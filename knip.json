{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreWorkspaces": [
    "extensions/**"
  ],
  "workspaces": {
    ".": {
      "entry": [
        "src/instrumentation.node.ts",
        "src/proxy.ts",
        "src/app/plugins-registry.tsx",
        "src/app/plugins-routes.tsx",
        "src/app/field-renderer-init.tsx",
        "src/lib/generated/**/*.{ts,tsx}",
        "scripts/**/*.{ts,mjs,mts,js}"
      ],
      "project": [
        "src/**/*.{ts,tsx}",
        "scripts/**/*.{ts,mjs,mts,js}"
      ]
    },
    "packages/*": {
      "entry": [
        "src/index.{ts,tsx,mjs,mts}"
      ]
    },
    "packages/cli": {
      "entry": [
        "src/index.{ts,tsx,mjs,mts}",
        "bin/cinatra.mjs"
      ]
    }
  },
  "ignore": [
    "**/__fixtures__/**",
    "**/__tests__/__stubs__/**",
    "**/__tests__/fixtures/**",
    "**/tests/__stubs__/**",
    "**/tests/fixtures/**",
    "**/vendor/**",
    "src/lib/generated/**",
    "src/lib/__tests__/fixtures/**",
    "**/*.generated.{ts,tsx}",
    "tests/e2e/**",
    "**/vitest.integration.config.ts"
  ],
  "ignoreDependencies": [
    "tw-animate-css",
    "@queuedash/ui",
    "node-pg-migrate",
    "bpmn-moddle",
    "moddle-xml",
    "katex",
    "@axe-core/playwright",
    "@ag-ui/core",
    "@a2ui/web_core",
    "libnpmpublish",
    "@types/katex"
  ],
  "ignoreExportsUsedInFile": true
}
