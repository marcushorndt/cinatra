# Build / cache output
node_modules
.next
.turbo
.pnpm-store

# VCS / editor / agent dirs
.git
# Nested .git from the companion extension repos cloned into the working tree
# — keep the source, drop their git metadata.
**/.git
.gitignore
.vscode
.claude

# Extension source never enters the image from the build context. The image
# acquires the required-extension set INSIDE the build from the committed
# cinatra-required-extensions.lock.json (SHA-pinned + integrity-verified;
# see the Dockerfile acquire step), so a local dev clone tree cannot leak an
# unpinned/divergent copy into the image.
extensions

# Local env / data — never bake into image
.env
.env.*
!.env.example
data
backups
downloads

# Sub-projects that ship outside the cinatra app image
docker/drupal
dev/wordpress-plugin
dev/drupal-module

# Docs / tests / scratch
docs
tests
test-*.ts
*.log
# Unit-test files never ship in the image. The in-image type-safety net
# (next build's tsc on a LOCAL docker build; CI=true skips it) must check the
# image's REAL compile surface: the acquired bootable extension set has no
# business resolving test-only relative imports of extensions outside that
# set (e.g. seed-pack manifest tests). The full-tree typecheck with every
# extension cloned back remains the CI merge gate for tests.
**/__tests__
**/__mocks__
**/*.test.*
**/*.spec.*

# Generated at build time inside the image (RUN pnpm build:auth-migrate-bundle);
# keep any stale local copy out of the build context so it's always fresh.
scripts/better-auth-migrate.bundle.mjs

# OS
.DS_Store
