# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
node_modules
/.pnpm-store
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# generated build artifact (produced by `pnpm build:auth-migrate-bundle`,
# emitted into the Docker image at build time — never committed)
scripts/better-auth-migrate.bundle.mjs

# misc
.DS_Store
*.pem

# local runtime data
/data/
/generated/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo

# Claude Code memory (local-only, not for version control)
memory/
next-env.d.ts

# Claude Code (ephemeral session data)
.claude/

# Python
__pycache__/
*.py[cod]
.langgraph_api/
# cinatra agents lockfile (runtime output)
cinatra-agents.lock

# A2A dev peer servers (cinatra-ai/a2a-servers-dev); synced by `cinatra setup`
# into dev/a2a-peers/ (cinatra.devApps). Source of truth is the companion repo.
dev/a2a-peers/

# Drupal config sync — generated at runtime by drush config:export, not committed
docker/drupal/config/sync/

# Playwright MCP transient artifacts (not source)
.playwright-mcp/
option-a-agents-rendered.png
option-a-agents-with-data.png

# Playwright dashboard-live-verify
tests/e2e/dashboards/.auth/
tests/e2e/workflows/.auth/
tests/e2e/rbac/.auth/
tests/e2e/render-smoke/.auth/
playwright-report/
test-results/

# Published-marker files are generated at publish time (by
# materialize-agent-package.ts) or backfilled at boot (instrumentation.node.ts).
# They are runtime metadata, not source — exclude them from git so they
# don't pollute diffs every time an agent is republished with a new
# `oasSha256`. The wayflow loader is the only consumer and reads them
# straight from disk.
agents/**/.cinatra-published.json
# (same markers, real path under the extension tree + any future scope)
extensions/**/.cinatra-published.json

# Companion extension source — the @cinatra-ai/* extensions live in their own
# repos (cinatra-ai/<slug>) and are CLONED BACK into extensions/cinatra-ai/ for
# dev (cinatra setup dev) and CI (the clone-extensions action). The clones are not
# committed here. A private in-tree vendor extension (extensions/<vendor>/)
# stays tracked in-tree, and the vendored anthropics bundle has its own rule below.
extensions/cinatra-ai/

# Per-worktree marker dropped on `cinatra setup branch` failure (never committed)
.cinatra-setup-branch-failed
playwright-report-design/

# BEGIN cinatra-vendored-bundles (managed by scripts/vendor-anthropic-skills.mjs — do not edit by hand)
extensions/anthropics/skills/
# END cinatra-vendored-bundles

# Runtime-generated dashboards data + diagnostics (never commit)
packages/dashboards/data/

# Dev-app clones (cinatra-ai/wordpress-plugin, cinatra-ai/drupal-module);
# synced by `cinatra setup`. Source of truth is the companion repos, not this tree.
dev/wordpress-plugin/
dev/drupal-module/

# Playwright WP/Drupal UAT seed IDs (regenerated each run)
tests/e2e/wp-drupal-uat/.uat/

# Extension publish-wave tarball artifacts (regenerated by extension pack/publish runs)
extensions/**/*.tgz

