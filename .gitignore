# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# --- Dependencies ---
node_modules
/.pnpm-store

# --- Build output ---
/.next/
/out/
next-env.d.ts
*.tsbuildinfo
packages/*/dist/

# --- Testing ---
coverage/

# --- Debug logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Env files & secrets ---
.env*
!.env.example
*.pem
# Narrow, generated WayFlow container env (host secrets the wayflow service
# needs: CINATRA_BRIDGE_TOKEN / OPENAI_API_KEY / WAYFLOW_BASE_URL). Synced from
# .env.local by scripts/gen-wayflow-env.mjs on every `npm run services`. The
# `.env*` glob above does NOT match this name, so it is listed explicitly.
docker/wayflow/.wayflow.env

# --- OS / misc ---
.DS_Store

# --- Claude Code (local-only: memory + ephemeral session data) ---
memory/
.claude/

# --- Python (docker/wayflow) ---
__pycache__/
*.py[cod]

# --- Local runtime data (generated, never committed) ---
/data/
/generated/
cinatra-agents.lock
.cinatra-setup-branch-failed
# generated by `pnpm build:auth-migrate-bundle`, emitted into the Docker image at build time
scripts/better-auth-migrate.bundle.mjs
# generated at runtime by `drush config:export`
docker/drupal/config/sync/

# --- Agent publish markers (runtime metadata in the agents/ tree) ---
agents/**/.cinatra-published.json

# --- Dev-app clones (synced by `cinatra setup`; source of truth = companion repos) ---
/dev/

# --- Extensions (root-level clone target for @cinatra-ai/* + vendored bundles; nothing here is tracked) ---
/extensions/

# --- Playwright / e2e artifacts ---
playwright-report/
playwright-report-design/
test-results/
.playwright-mcp/
# per-suite auth state + seed artifacts; keep each .auth/.gitignore anchor tracked.
tests/e2e/**/.auth/*
!tests/e2e/**/.auth/.gitignore
# WP/Drupal UAT seed IDs (regenerated each run)
tests/e2e/wp-drupal-uat/.uat/

# Internal planning notes (local only)
.planning/

# --- cinatra-ai org baseline (union-merged from cinatra-ai/ci config/baseline.gitignore) ---

# Dependencies (node / pnpm)
.pnpm-store/

# Build output (monorepo-typical)
dist/
# re-include the deliberately tracked vendored builds
!packages/mcp-server/vendor/*/dist/
!packages/mcp-server/vendor/*/dist/**
build/
out/
.next/
.turbo/

# Logs and caches
*.log
pnpm-debug.log*
.cache/
.eslintcache

# OS cruft
Thumbs.db
Desktop.ini

# Editor / IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Env files and secrets
*.key
