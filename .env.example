# =============================================================================
# Cinatra — Local Development Environment
# =============================================================================
# Copy this file to .env.local and fill in the values.
#   cp .env.example .env.local

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=
CINATRA_RUNTIME_MODE=development
# Branch isolation — set per worktree to avoid BullMQ queue conflicts with other dev servers.
# Auto-set per worktree by the worktree setup step.
# BULLMQ_QUEUE_NAME=cinatra-background-jobs

# -----------------------------------------------------------------------------
# Database (Postgres via docker-compose)
# -----------------------------------------------------------------------------
# Required at BUILD time too (next build), not just at runtime — a placeholder
# value is sufficient for the build (no real DB connection is made).
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:5434/postgres

# -----------------------------------------------------------------------------
# Nango (via docker-compose)
# -----------------------------------------------------------------------------
NANGO_SERVER_URL=http://localhost:3003
NANGO_DATABASE_URL=postgresql://nango:nango@127.0.0.1:5435/nango
# Local dev only — generate a new key with: openssl rand -base64 32
NANGO_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Graphiti — Objects Layer (via docker-compose)
# -----------------------------------------------------------------------------
# Graphiti MCP server URL. Defaults to http://graphiti:8000 (Docker internal)
# which only resolves inside the container network. Set to localhost for the host app.
# The client appends /mcp to this URL for tool calls.
GRAPHITI_URL=http://localhost:8000
# OpenAI API key — OPTIONAL. The app/assistant do NOT need it (the assistant's
# model provider is configured in-app at /setup/ai). It is used ONLY by the
# Graphiti objects-layer container for entity embeddings — set it (here, passed
# via docker-compose) if/when you use the objects/Graphiti layer; leaving it
# empty is fine for a fresh `make dev` boot.
# Without this, objects_save and objects_list will fail at runtime.
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# External APIs (optional — configure as needed)
# -----------------------------------------------------------------------------
# Other providers (Anthropic, Gemini, Apollo, etc.) are connected through Nango or the app UI.
# No environment variables needed for those.

# ---------------------------------------------------------------------------
# A2A dev peer servers (opt-in via `docker compose --profile a2a-peers up -d --build`).
# `cinatra setup dev` clones cinatra-ai/a2a-servers-dev into dev/a2a-peers/ (gitignored).
# Comma-separated list of peer URLs. Peers auto-register in /connectors/a2a-server on dev boot.
# Default set after opting into the `a2a-peers` compose profile (number-bob/10003 is a
# CLI client with no HTTP endpoint, so it is omitted):
# CINATRA_A2A_DEV_PEER_URLS=http://localhost:10001,http://localhost:10002,http://localhost:10004,http://localhost:10005,http://localhost:10006,http://localhost:10007
# ---------------------------------------------------------------------------
CINATRA_A2A_DEV_PEER_URLS=
# LLM-backed peers need a Google/Gemini key: adk_expense_reimbursement checks
# GEMINI_API_KEY; dice_agent_rest checks GOOGLE_API_KEY. The other peers need no key.
# GEMINI_API_KEY=

# WayFlow runtime (multi-tenant model)
# A single unified WayFlow runtime hosts every installed agent under
# `/agents/<vendor>/<slug>/`, mirroring the on-disk `agents/<vendor>/<slug>/`
# layout. Agent URLs are derived from `agent_templates.packageName`
# (`@<vendor>/<slug>`) by `resolveWayflowUrl` — see
# `packages/agent-builder/src/wayflow-url.ts`. No per-agent env-var configuration
# is required; new agents become reachable on container restart.
WAYFLOW_BASE_URL=http://localhost:3010

# ---------------------------------------------------------------------------
# /api/llm-bridge and /api/a2a/agents/* shared-secret auth
# ---------------------------------------------------------------------------
# CINATRA_BRIDGE_TOKEN is the REQUIRED shared secret validated by
# isAuthorizedBridgeRequest in src/lib/wayflow-bridge-auth.ts. WayFlow
# containers pass this value as the X-Cinatra-Bridge-Token header on every
# ApiNode call to /api/llm-bridge and /api/a2a/agents/* (the container side is
# wired via docker/wayflow/agent_loader.py
# _patch_api_call_step_bridge_token; docker-compose.yml passes the value
# through as ${CINATRA_BRIDGE_TOKEN}).
#
# Strict-token-only auth. The legacy bypass env-var escape
# hatch and the X-Forwarded-For loopback fallback have been REMOVED.
# When CINATRA_BRIDGE_TOKEN is unset, ALL requests are denied (403). The
# helper uses timingSafeEqual with a length-mismatch short-circuit to defeat
# both forgery and timing attacks.
#
# SET this in production / staging — the container patch
# ensures every WayFlow ApiNode call carries the X-Cinatra-Bridge-Token
# header. Both sides MUST use the same value or all WayFlow bridge/proxy
# calls return 403.
#
# Recommended value: 32-char hex secret, e.g. `openssl rand -hex 32`.
# CINATRA_BRIDGE_TOKEN=

# ---------------------------------------------------------------------------
# Encryption key — used by AES-256-GCM to encrypt registry credentials.
# ---------------------------------------------------------------------------
# In development this value is generated automatically on first server boot
# and persisted to .env.local. Production deployments MUST set this
# explicitly — losing the key means losing access to all encrypted data.
# Recommended value: 32-byte hex secret, e.g. `openssl rand -hex 32`.
# CINATRA_ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
# Sentry — error reporting and tracing.
#
# Compatible with both Sentry (self-hosted or SaaS) and GlitchTip (Sentry-API
# compatible, lighter to self-host). Cinatra never decides between the two —
# point SENTRY_DSN at whichever you operate.
#
# Leaving SENTRY_DSN unset disables Sentry entirely. Dev default = no Sentry,
# zero runtime overhead, no startup log noise.
# ---------------------------------------------------------------------------
# Runtime — provided at every process start. Safe to commit to .env.example.
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=development
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_RELEASE=

# Browser-side capture — Next.js only inlines envs prefixed with NEXT_PUBLIC_
# into the client bundle. To enable Sentry in the browser, set this variable
# (typically to the same DSN as SENTRY_DSN). Leaving it unset disables
# browser-side capture while keeping server / edge / worker capture working.
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0
# NEXT_PUBLIC_SENTRY_RELEASE=

# Build-time ONLY — used by withSentryConfig() in next.config.ts to upload
# source maps to Sentry/GlitchTip. DO NOT set these in production runtime
# environments; they're only needed in CI where the build runs.
# SENTRY_AUTH_TOKEN=    # BUILD-TIME ONLY
# SENTRY_ORG=           # BUILD-TIME ONLY
# SENTRY_PROJECT=       # BUILD-TIME ONLY

# ---------------------------------------------------------------------------
# MCP dev-only admin bypass — local development ONLY.
# ---------------------------------------------------------------------------
# Skips OAuth verification AND stamps `platformRole: "platform_admin"` on
# requests reaching a trusted dev host, so admin-gated MCP handlers work
# without re-auth when the 30-day mcp-remote OAuth token expires.
#
# Both guards must hold (in addition to NODE_ENV != production):
#   1. CINATRA_MCP_DEV_ADMIN_BYPASS=true   — explicit opt-in for this feature
#   2. Request reaches a trusted host — by default just loopback. To extend
#      trust to a stable dev tunnel hostname (Tailscale Serve, named
#      Cloudflare Tunnel, ngrok stable subdomain), list it explicitly:
#
#        CINATRA_MCP_DEV_TRUSTED_HOSTS=my-box.tailnet000.ts.net,my-tunnel.cinatra.dev
#
# SECURITY: any caller who can reach a listed hostname becomes an
# unauthenticated platform admin on this MCP server. Never list a
# publicly-reachable hostname (Tailscale Funnel, public ngrok, named
# public Cloudflare Tunnel) unless you accept that exposure.
#
# Leave both unset in production. NODE_ENV=production silently disables
# the bypass regardless of these flags (defense in depth).
# CINATRA_MCP_DEV_ADMIN_BYPASS=true
# CINATRA_MCP_DEV_TRUSTED_HOSTS=
