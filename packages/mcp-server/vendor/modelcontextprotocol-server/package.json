        "types": "./dist/shimsNode.d.mts",
        "import": "./dist/shimsNode.mjs"
      },
      "default": {
        "types": "./dist/shimsNode.d.mts",
        "import": "./dist/shimsNode.mjs"
      }
    }
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "zod": "^4.3.6"
  }
}
