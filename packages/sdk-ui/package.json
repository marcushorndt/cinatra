{
  "name": "@cinatra-ai/sdk-ui",
  "version": "0.1.0",
  "description": "Cinatra-design-strict React composition primitives. Page chrome (Main / PageHeader / PageContent), canonical patterns (StatusPill, ExtensionCard), and helpers (cn, extension accent palette). Pairs with @cinatra-ai/design (CSS tokens).",
  "license": "SEE LICENSE IN LICENSE",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./marketplace": "./src/marketplace.ts",
    "./nango": "./src/nango.ts",
    "./lib/utils": "./src/lib/utils.ts",
    "./lib/extension-accent": "./src/lib/extension-accent.ts"
  },
  "files": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "cinatra",
    "design-system",
    "react",
    "shadcn",
    "page-chrome"
  ],
  "dependencies": {
    "@nangohq/frontend": "^0.70.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.20.0",
    "radix-ui": "^1.6.0",
    "react": "^19.2.6",
    "react-dom": "19.2.6",
    "tailwind-merge": "^3.6.0"
  }
}
