{
  "name": "@cinatra-ai/design",
  "version": "0.1.0",
  "description": "Cinatra design tokens, fonts, and brand assets. Tech-stack-independent — pure CSS + brand asset exports for consumption by any Cinatra-design-strict surface.",
  "license": "SEE LICENSE IN LICENSE",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./tokens.css": "./src/tokens.css",
    "./theme.css": "./src/theme.css",
    "./utilities.css": "./src/utilities.css",
    "./fonts.css": "./src/fonts.css",
    "./index.css": "./src/index.css",
    "./brand/logo": "./src/brand/logo.ts",
    "./brand/colors": "./src/brand/colors.ts",
    "./brand/icon.svg": "./src/brand/icon.svg",
    "./brand/apple-icon.png": "./src/brand/apple-icon.png"
  },
  "files": [
    "src/**/*.css",
    "src/**/*.ts",
    "src/**/*.svg",
    "src/**/*.png",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "cinatra",
    "design-system",
    "design-tokens",
    "css-tokens",
    "tailwind-v4",
    "brand"
  ]
}
